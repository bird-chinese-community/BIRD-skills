{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "arrowParens": "avoid",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "useTabs": false,
  "ignorePatterns": [
    "node_modules/",
    ".git/",
    "__pycache__/",
    "*.py[cod]",
    ".venv/",
    ".uv/",
    "docs/_build/",
    "dist/",
    "build/",
    "*.md",
    "*.py"
  ]
}
